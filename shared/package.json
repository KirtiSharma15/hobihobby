{
    "name": "@hobihobby/shared",
    "version": "1.0.0",
    "description": "Shared business logic, types, and utilities for HobiHobby",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.esm.js",
        "require": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    },
    "files": [
      "dist"
    ],
    "scripts": {
      "build": "rollup -c",
      "dev": "rollup -c -w",
      "clean": "rm -rf dist"
    },
    "dependencies": {
      "@reduxjs/toolkit": "^2.0.1",
      "axios": "^1.6.2"
    },
    "devDependencies": {
      "@rollup/plugin-commonjs": "^25.0.7",
      "@rollup/plugin-node-resolve": "^15.2.3",
      "@rollup/plugin-typescript": "^11.1.5",
      "rollup": "^4.6.1",
      "typescript": "^5.1.3"
    },
    "peerDependencies": {
      "react": ">=18.0.0"
    }
  }